{
  "name": "grainlet",
  "version": "1.0.22",
  "description": "Fine-grained signals, JSX, routing, and SSR for the web",
  "type": "module",
  "license": "MIT",
  "main": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./route": {
      "types": "./route.d.ts",
      "default": "./route/index.js"
    },
    "./forms": {
      "types": "./forms.d.ts",
      "default": "./forms/index.js"
    },
    "./ssr": {
      "types": "./ssr.d.ts",
      "default": "./ssr/index.js"
    },
    "./jsx-runtime": {
      "types": "./jsx-runtime.d.ts",
      "default": "./core/jsx-compiler-new/jsx-runtime.js"
    },
    "./jsx-runtime.js": {
      "types": "./jsx-runtime.d.ts",
      "default": "./core/jsx-compiler-new/jsx-runtime.js"
    },
    "./jsx-dev-runtime": {
      "types": "./jsx-dev-runtime.d.ts",
      "default": "./core/jsx-compiler-new/jsx-dev-runtime.js"
    },
    "./jsx-dev-runtime.js": {
      "types": "./jsx-dev-runtime.d.ts",
      "default": "./core/jsx-compiler-new/jsx-dev-runtime.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "route.d.ts",
    "forms.d.ts",
    "ssr.d.ts",
    "jsx-runtime.d.ts",
    "jsx-dev-runtime.d.ts",
    "types",
    "signals",
    "core",
    "route",
    "forms",
    "ssr",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "test": "node test/keyed-unmount.test.mjs && node test/virtual-list.test.mjs && node test/render-async.test.mjs && node test/for-bench-repro.test.mjs && node test/template-for-smoke.test.mjs && node test/forms-paths.test.mjs && node test/forms-createForm.test.mjs && node test/forms-provider-smoke.test.mjs && node test/forms-yup.test.mjs && node test/forms-validators.test.mjs"
  },
  "peerDependencies": {
    "yup": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "yup": {
      "optional": true
    }
  },
  "devDependencies": {
    "jsdom": "^26.1.0",
    "yup": "^1.7.1"
  },
  "keywords": [
    "grainlet",
    "grain",
    "signals",
    "jsx",
    "router",
    "ssr",
    "fine-grained",
    "typescript"
  ]
}
